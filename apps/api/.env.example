# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit real credentials.

# PostgreSQL connection (local Docker default shown):
DATABASE_URL="postgresql://quickbasket:quickbasket@localhost:5432/quickbasket"

# Auth secrets (min 16 chars each; use long random strings in production):
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

PORT=3000
NODE_ENV=development
CORS_ORIGINS="*"

# Optional cache (Phase 2). Omit to run without Redis (cache no-ops):
REDIS_URL="redis://localhost:6379"
